{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DocQuery": {
    "Provider": "Local",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "EmbeddingModel": "nomic-embed-text",
      "ChatModel": "llama3"
    },
    "Azure": {
      "OpenAI": {
        "Endpoint": "https://YOUR_RESOURCE.openai.azure.com/",
        "ApiKey": "YOUR_KEY",
        "ChatDeployment": "gpt-4o",
        "EmbeddingDeployment": "text-embedding-ada-002"
      },
      "Search": {
        "Endpoint": "https://YOUR_RESOURCE.search.windows.net",
        "ApiKey": "YOUR_KEY",
        "IndexName": "docquery-index"
      }
    }
  }
}
